{
  "name": "@wizard-archive/ui",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "sideEffects": false,
  "exports": {
    "./components/*": {
      "types": "./src/components/*",
      "default": "./src/components/*"
    },
    "./drag-drop/*": {
      "types": "./src/drag-drop/*",
      "default": "./src/drag-drop/*"
    },
    "./file-upload/*": {
      "types": "./src/file-upload/*",
      "default": "./src/file-upload/*"
    },
    "./hooks/*": {
      "types": "./src/hooks/*",
      "default": "./src/hooks/*"
    },
    "./panel-preferences/*": {
      "types": "./src/panel-preferences/*",
      "default": "./src/panel-preferences/*"
    },
    "./shadcn/*": {
      "types": "./src/shadcn/*",
      "default": "./src/shadcn/*"
    },
    "./storage/*": {
      "types": "./src/storage/*",
      "default": "./src/storage/*"
    },
    "./theme/*": {
      "types": "./src/theme/*",
      "default": "./src/theme/*"
    },
    "./utils/*": {
      "types": "./src/utils/*.ts",
      "default": "./src/utils/*.ts"
    }
  },
  "dependencies": {
    "@base-ui/react": "^1.6.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "color": "^5.0.2",
    "input-otp": "^1.4.2",
    "lucide-react": "^0.541.0",
    "react": "^19.1.1",
    "react-dom": "^19.1.1",
    "react-resizable-panels": "^3.0.5",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.3.1"
  }
}
