{
  "name": "wizard-archive",
  "private": true,
  "sideEffects": false,
  "type": "module",
  "packageManager": "pnpm@10.12.4",
  "engines": {
    "node": ">=22.12.0"
  },
  "scripts": {
    "dev": "npx convex dev --once && concurrently -r npm:dev:web npm:dev:convex",
    "dev:web": "vite dev",
    "dev:convex": "npx convex dev",
    "build": "vite build && tsc --noEmit",
    "start": "node .output/server/index.mjs",
    "format": "prettier --write .",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "test:frontend": "vitest run",
    "test:frontend:watch": "vitest",
    "test:frontend:coverage": "vitest run --coverage",
    "test:backend": "vitest --config convex/vitest.config.mts",
    "test:backend:run": "vitest run --config convex/vitest.config.mts",
    "test:e2e": "node --env-file-if-exists=.env.local ./node_modules/@playwright/test/cli.js test",
    "test:e2e:ui": "node --env-file-if-exists=.env.local ./node_modules/@playwright/test/cli.js test --ui",
    "prepare": "husky"
  },
  "dependencies": {
    "@atlaskit/pragmatic-drag-and-drop": "^1.7.7",
    "@atlaskit/pragmatic-drag-and-drop-auto-scroll": "^2.1.5",
    "@base-ui-components/react": "1.0.0-rc.0",
    "@base-ui/react": "^1.0.0",
    "@blocknote/core": "^0.46.2",
    "@blocknote/react": "^0.46.2",
    "@blocknote/shadcn": "^0.46.2",
    "@convex-dev/better-auth": "0.11.3",
    "@convex-dev/prosemirror-sync": "^0.2.1",
    "@convex-dev/react-query": "0.1.0",
    "@convex-dev/resend": "^0.2.3",
    "@dnd-kit/modifiers": "^9.0.0",
    "@tailwindcss/postcss": "^4.1.12",
    "@tanstack/devtools-vite": "^0.3.12",
    "@tanstack/react-form": "^1.28.4",
    "@tanstack/react-query": "^5.90.21",
    "@tanstack/react-query-devtools": "^5.91.3",
    "@tanstack/react-router": "^1.166.3",
    "@tanstack/react-router-devtools": "^1.166.3",
    "@tanstack/react-start": "^1.166.3",
    "@tiptap/core": "^3.18.0",
    "@tiptap/pm": "^3.18.0",
    "better-auth": "1.5.5",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "cmdk": "^1.1.1",
    "color": "^5.0.2",
    "convex": "^1.32.0",
    "date-fns": "^4.1.0",
    "embla-carousel-react": "^8.6.0",
    "escape-html": "^1.0.3",
    "input-otp": "^1.4.2",
    "jszip": "^3.10.1",
    "lodash-es": "^4.17.21",
    "lucide-react": "^0.541.0",
    "motion": "^12.24.12",
    "next-themes": "^0.4.6",
    "pdfjs-dist": "5.4.296",
    "pluralize": "^8.0.0",
    "postcss": "^8.5.6",
    "qrcode": "^1.5.4",
    "react": "^19.1.1",
    "react-day-picker": "^9.12.0",
    "react-dom": "^19.1.1",
    "react-pdf": "^10.4.1",
    "react-resizable-panels": "^3.0.5",
    "react-zoom-pan-pinch": "^3.7.0",
    "recharts": "2.15.4",
    "redaxios": "^0.5.1",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.3.1",
    "vaul": "^1.1.2",
    "zustand": "^5.0.11"
  },
  "devDependencies": {
    "@edge-runtime/vm": "^5.0.0",
    "@eslint/js": "^9.36.0",
    "@playwright/test": "^1.58.2",
    "@tailwindcss/vite": "^4.1.12",
    "@tanstack/eslint-config": "^0.3.4",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/color": "^4.2.0",
    "@types/escape-html": "^1.0.4",
    "@types/lodash-es": "^4.17.12",
    "@types/node": "^24.3.0",
    "@types/pluralize": "^0.0.33",
    "@types/qrcode": "^1.5.6",
    "@types/react": "^19.1.11",
    "@types/react-dom": "^19.1.7",
    "@typescript-eslint/eslint-plugin": "^8.45.0",
    "@typescript-eslint/parser": "^8.45.0",
    "@vitejs/plugin-react": "^5.1.2",
    "@vitest/coverage-v8": "^4.1.2",
    "autoprefixer": "^10.4.21",
    "babel-plugin-react-compiler": "1.0.0",
    "concurrently": "~9.2.0",
    "convex-test": "^0.0.44",
    "eslint": "^9.36.0",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^6.1.0",
    "eslint-plugin-react-refresh": "^0.4.23",
    "globals": "^16.5.0",
    "husky": "^9.1.7",
    "jsdom": "^29.0.1",
    "lint-staged": "^16.4.0",
    "prettier": "^3.6.2",
    "tailwindcss": "^4.1.12",
    "tw-animate-css": "^1.3.7",
    "typescript": "^5.9.2",
    "vite": "^7.1.3",
    "vite-tsconfig-paths": "^5.1.4",
    "vitest": "^4.1.2"
  },
  "lint-staged": {
    "*.{ts,tsx}": [
      "eslint --fix --no-warn-ignored",
      "prettier --write"
    ],
    "*.{js,mjs,cjs}": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.{json,css,md,yml,yaml}": [
      "prettier --write"
    ]
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild",
      "@tailwindcss/oxide"
    ]
  }
}
