{
  "name": "wizard-archive",
  "private": true,
  "type": "module",
  "sideEffects": false,
  "scripts": {
    "dev": "vp run build:editor-package && vp exec convex dev --once && vp exec concurrently -r \"vp run dev:web\" \"vp run dev:convex\" \"vp run dev:editor\"",
    "dev:web": "vp dev",
    "dev:convex": "vp exec convex dev",
    "dev:editor": "vp pack --watch --no-clean",
    "build": "vp run build:editor-package && vp build",
    "build:production": "vp run build:editor-package && vp build --mode production",
    "start": "vp exec node .output/server/index.mjs",
    "generate:brand-assets": "vp exec node scripts/generate-brand-assets.mjs",
    "check": "vp check",
    "check:editor-package": "vp run build:editor-package && vp exec tsc -p packages/editor/tsconfig.json --noEmit",
    "check:ui-package": "vp exec tsc -p packages/ui/tsconfig.json --noEmit",
    "format": "vp fmt .",
    "lint": "vp lint . && vp run lint:convex",
    "lint:fix": "vp lint . --fix && vp run lint:convex:fix",
    "lint:convex": "vp exec eslint convex/ --no-warn-ignored",
    "lint:convex:fix": "vp exec eslint convex/ --fix --no-warn-ignored",
    "check:import-boundaries": "vp exec node scripts/check-import-boundaries.mjs",
    "test:frontend": "vp run build:editor-package && vp test run --config vitest.config.ts",
    "test:frontend:watch": "vp run build:editor-package && vp test --config vitest.config.ts",
    "test:frontend:coverage": "vp run build:editor-package && vp test run --config vitest.config.ts --coverage",
    "test:backend": "vp run build:editor-package && vp test run --config convex/vitest.config.mts && vp test run --config convex/vitest.entrypoints.config.mts",
    "test:backend:watch": "vp run build:editor-package && vp test --config convex/vitest.config.mts",
    "test:e2e": "vp exec node --env-file-if-exists=.env.local scripts/run-playwright.mjs",
    "test:e2e:ui": "vp exec node --env-file-if-exists=.env.local scripts/run-playwright.mjs --ui",
    "prepare": "vp config",
    "preview": "vp run build && vp exec wrangler dev",
    "cf-typegen": "vp exec wrangler types",
    "fallow": "vp exec fallow",
    "build:editor-package": "vp pack"
  },
  "dependencies": {
    "@base-ui/react": "^1.6.0",
    "@convex-dev/better-auth": "0.12.3",
    "@convex-dev/presence": "0.3.2",
    "@convex-dev/react-query": "0.1.0",
    "@convex-dev/resend": "^0.2.3",
    "@tailwindcss/postcss": "^4.1.12",
    "@tanstack/react-form": "^1.28.4",
    "@tanstack/react-query": "^5.90.21",
    "@tanstack/react-query-devtools": "^5.91.3",
    "@tanstack/react-router": "^1.166.3",
    "@tanstack/react-router-devtools": "^1.166.3",
    "@tanstack/react-start": "^1.166.3",
    "@wizard-archive/editor": "workspace:*",
    "@wizard-archive/ui": "workspace:*",
    "better-auth": "1.6.19",
    "color": "^5.0.2",
    "convex": "^1.35.1",
    "convex-helpers": "^0.1.114",
    "date-fns": "^4.1.0",
    "lodash-es": "^4.17.21",
    "lucide-react": "^0.541.0",
    "motion": "^12.24.12",
    "postcss": "^8.5.6",
    "react": "^19.1.1",
    "react-dom": "^19.1.1",
    "sharp": "^0.34.5",
    "sonner": "^2.0.7",
    "y-protocols": "^1.0.7",
    "yjs": "^13.6.29",
    "zod": "^4.4.3",
    "zustand": "^5.0.11"
  },
  "devDependencies": {
    "@cloudflare/vite-plugin": "^1.30.2",
    "@codecov/vite-plugin": "^1.9.1",
    "@convex-dev/eslint-plugin": "^1.2.2",
    "@edge-runtime/vm": "^5.0.0",
    "@eslint/compat": "^2.0.5",
    "@playwright/test": "^1.58.2",
    "@tailwindcss/vite": "^4.1.12",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@tsdown/css": "^0.22.3",
    "@types/color": "^4.2.0",
    "@types/lodash-es": "^4.17.12",
    "@types/node": "^24.3.0",
    "@types/react": "^19.1.11",
    "@types/react-dom": "^19.1.7",
    "@vitejs/plugin-react": "^5.1.2",
    "@vitest/coverage-v8": "catalog:",
    "autoprefixer": "^10.4.21",
    "babel-plugin-react-compiler": "1.0.0",
    "concurrently": "~9.2.0",
    "convex-test": "^0.0.44",
    "eslint": "^10.2.0",
    "fallow": "^2.40.1",
    "jsdom": "^29.0.1",
    "pdf-lib": "^1.17.1",
    "png-to-ico": "^3.0.1",
    "react-doctor": "^0.2.3",
    "tailwindcss": "^4.1.12",
    "tw-animate-css": "^1.3.7",
    "typescript": "^5.9.2",
    "typescript-eslint": "^8.58.1",
    "vite": "catalog:",
    "vite-plus": "catalog:",
    "vitest": "catalog:",
    "wrangler": "^4.78.0"
  },
  "engines": {
    "node": ">=22.12.0"
  },
  "packageManager": "pnpm@10.12.4"
}
