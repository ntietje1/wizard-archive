{
  "name": "wizard-archive",
  "private": true,
  "type": "module",
  "sideEffects": false,
  "scripts": {
    "dev": "npx convex dev --once && concurrently -r npm:dev:web npm:dev:convex",
    "dev:web": "vp dev",
    "dev:convex": "npx convex dev",
    "build": "vp build",
    "start": "node .output/server/index.mjs",
    "check": "vp check",
    "format": "vp fmt .",
    "lint": "vp lint .",
    "lint:fix": "vp lint . --fix",
    "lint:convex": "eslint convex/ --no-warn-ignored",
    "test:frontend": "vp test run --config vitest.config.ts",
    "test:frontend:watch": "vp test --config vitest.config.ts",
    "test:frontend:coverage": "vp test run --config vitest.config.ts --coverage",
    "test:backend": "vp test --config convex/vitest.config.mts",
    "test:backend:run": "vp test run --config convex/vitest.config.mts",
    "test:e2e": "node --env-file-if-exists=.env.local ./node_modules/@playwright/test/cli.js test",
    "test:e2e:ui": "node --env-file-if-exists=.env.local ./node_modules/@playwright/test/cli.js test --ui",
    "prepare": "vp config",
    "deploy:prod": "vp build --mode production && wrangler deploy",
    "preview": "vp build && wrangler dev",
    "cf-typegen": "wrangler types",
    "fallow": "fallow"
  },
  "dependencies": {
    "@atlaskit/pragmatic-drag-and-drop": "^1.7.7",
    "@base-ui-components/react": "1.0.0-rc.0",
    "@base-ui/react": "^1.0.0",
    "@blocknote/core": "^0.46.2",
    "@blocknote/react": "^0.46.2",
    "@blocknote/shadcn": "^0.46.2",
    "@convex-dev/better-auth": "0.11.3",
    "@convex-dev/react-query": "0.1.0",
    "@convex-dev/resend": "^0.2.3",
    "@tailwindcss/postcss": "^4.1.12",
    "@tanstack/devtools-vite": "^0.3.12",
    "@tanstack/react-form": "^1.28.4",
    "@tanstack/react-query": "^5.90.21",
    "@tanstack/react-query-devtools": "^5.91.3",
    "@tanstack/react-router": "^1.166.3",
    "@tanstack/react-router-devtools": "^1.166.3",
    "@tanstack/react-start": "^1.166.3",
    "@tiptap/pm": "^3.18.0",
    "@xyflow/react": "^12.10.2",
    "better-auth": "1.5.5",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "cmdk": "^1.1.1",
    "color": "^5.0.2",
    "convex": "^1.32.0",
    "date-fns": "^4.1.0",
    "embla-carousel-react": "^8.6.0",
    "escape-html": "^1.0.3",
    "html-to-image": "^1.11.13",
    "input-otp": "^1.4.2",
    "jszip": "^3.10.1",
    "lib0": "^0.2.117",
    "lodash-es": "^4.17.21",
    "lucide-react": "^0.541.0",
    "motion": "^12.24.12",
    "pdfjs-dist": "5.4.296",
    "perfect-freehand": "^1.2.3",
    "postcss": "^8.5.6",
    "react": "^19.1.1",
    "react-day-picker": "^9.12.0",
    "react-dom": "^19.1.1",
    "react-pdf": "^10.4.1",
    "react-resizable-panels": "^3.0.5",
    "react-zoom-pan-pinch": "^3.7.0",
    "recharts": "2.15.4",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.3.1",
    "vaul": "^1.1.2",
    "y-protocols": "^1.0.6",
    "yjs": "^13.6.29",
    "zustand": "^5.0.11"
  },
  "devDependencies": {
    "@cloudflare/vite-plugin": "^1.30.2",
    "@convex-dev/eslint-plugin": "^1.2.2",
    "@edge-runtime/vm": "^5.0.0",
    "@eslint/compat": "^2.0.5",
    "@playwright/test": "^1.58.2",
    "@tailwindcss/vite": "^4.1.12",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/color": "^4.2.0",
    "@types/escape-html": "^1.0.4",
    "@types/lodash-es": "^4.17.12",
    "@types/node": "^24.3.0",
    "@types/react": "^19.1.11",
    "@types/react-dom": "^19.1.7",
    "@vitejs/plugin-react": "^5.1.2",
    "@vitest/coverage-v8": "^4.1.2",
    "autoprefixer": "^10.4.21",
    "babel-plugin-react-compiler": "1.0.0",
    "concurrently": "~9.2.0",
    "convex-test": "^0.0.44",
    "eslint": "^10.2.0",
    "fallow": "^2.26.0",
    "jsdom": "^29.0.1",
    "tailwindcss": "^4.1.12",
    "tw-animate-css": "^1.3.7",
    "typescript": "^5.9.2",
    "typescript-eslint": "^8.58.1",
    "vite": "npm:@voidzero-dev/vite-plus-core@latest",
    "vite-plus": "latest",
    "vitest": "npm:@voidzero-dev/vite-plus-test@latest",
    "wrangler": "^4.78.0"
  },
  "engines": {
    "node": ">=22.12.0"
  },
  "packageManager": "pnpm@10.12.4",
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild",
      "@tailwindcss/oxide"
    ],
    "overrides": {
      "vite": "npm:@voidzero-dev/vite-plus-core@latest",
      "vitest": "npm:@voidzero-dev/vite-plus-test@latest"
    },
    "peerDependencyRules": {
      "allowAny": [
        "vite",
        "vitest"
      ],
      "allowedVersions": {
        "vite": "*",
        "vitest": "*"
      }
    }
  }
}
